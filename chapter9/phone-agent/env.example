# 复制为 .env 后填写。本实验用一个聊天 LLM 驱动 ReAct Agent 与被叫方模拟。
# 至少配置 OPENAI_API_KEY 或 OPENROUTER_API_KEY 其一即可。

# 方式一（推荐）：OpenRouter。gpt-5.6* 直连 OpenAI 需组织实名认证，走 OpenRouter 免此步。
OPENROUTER_API_KEY=

# 方式二：直连 OpenAI。设置后优先直连；模型默认 gpt-5.6-luna（可用 OPENAI_MODEL 覆盖）。
# OPENAI_API_KEY=

# 可选：聊天模型（默认 gpt-5.6-luna）。回退到 OpenRouter 时会自动映射为 openai/gpt-5.6-luna。
# OPENAI_MODEL=gpt-5.6-luna

# 可选：改用 Moonshot 的 kimi-k3（OpenAI 兼容网关）——把 kimi 密钥填到 OPENAI_API_KEY，
# 并设置 base_url 与模型：
# OPENAI_API_KEY=<你的 Moonshot Key>
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=kimi-k3

# 解析优先级：OPENAI_API_KEY（可选 OPENAI_BASE_URL 网关）> OPENROUTER_API_KEY（自动映射模型）。
#
# —— 真实接入 PineClaw Voice API 时才需要（本模拟不需要）——
# PINECLAW_API_KEY=
